# Banco de dados (já existia no projeto)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# Chave JWT — gere uma aleatória com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-uma-chave-aleatoria-de-64-caracteres

# Porta (opcional — o Render define automaticamente)
PORT=5000
