# =====================================================
# BANCO DE DADOS
# =====================================================
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# =====================================================
# JWT — gere uma chave forte com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =====================================================
JWT_SECRET_KEY=troque-por-uma-chave-aleatoria-de-64-caracteres

# =====================================================
# SUPERADMIN — credenciais do administrador principal.
# O hash da senha é gerado automaticamente na primeira
# execução. Nunca coloque isso no código-fonte.
# =====================================================
SUPERADMIN_EMAIL=seu@email.com
SUPERADMIN_SENHA=uma-senha-forte-aqui
SUPERADMIN_NOME=SeuNome

# =====================================================
# CORS — domínios permitidos (separados por vírgula).
# Deixe em branco para usar localhost em desenvolvimento.
# =====================================================
ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# =====================================================
# FLASK
# "true" em desenvolvimento, "false" em produção
# =====================================================
FLASK_DEBUG=false

# =====================================================
# PORTA (o Render define automaticamente)
# =====================================================
PORT=5000

# =====================================================
# E-MAIL (para envio de reset de senha)
# Descomente e configure quando integrar SendGrid/Resend
# =====================================================
# SENDGRID_API_KEY=SG.xxx
# EMAIL_REMETENTE=noreply@seudominio.com
